# Auto detect text files and perform LF normalization
* text=auto

# Java source files
*.java text eol=lf
*.sh text eol=lf
*.py text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.txt text eol=lf

# Binary files
*.jar binary
*.pt binary
*.onnx binary
*.so binary
*.dylib binary
*.dll binary

